---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="שיטת הטיפול" description="טיפול LI-CBT בגישת ACT — מה זה אומר ואיך זה עובד">

  <section class="max-w-3xl mx-auto px-6 pt-14 pb-12">
    <h1 class="text-3xl font-bold text-gray-800 mb-2 text-center">שיטת הטיפול</h1>
    <p class="text-center text-gray-400 text-sm mb-12">טיפול LI-CBT · ACT · CBT</p>

    <!-- CBT -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-gray-800 mb-1">CBT — Cognitive Behavior Therapy</h2>
      <p class="text-sm text-gray-400 mb-3">טיפול קוגנטיבי-התנהגותי</p>
      <p class="text-gray-600 leading-relaxed">
        טיפול קוגנטיבי-התנהגותי הוא גישה מובנית, ממוקדת מטרה ומבוססת ראיות. הוא מתמקד בזיהוי דפוסי חשיבה והתנהגות שגורמים לנו לסבל, ובמתן כלים לשנות אותם.
      </p>
    </div>

    <hr class="border-gray-100 mb-8" />

    <!-- LI -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-gray-800 mb-1">LI — Low Intensity</h2>
      <p class="text-sm text-gray-400 mb-3">טיפול בעצימות נמוכה</p>
      <p class="text-gray-600 leading-relaxed">
        טיפול בעצימות נמוכה, המאפשר מענה קצר וממוקד לצרכים של המטופל. יעיל במיוחד עבור חרדה, דכדוך ולחץ יומיומי.
      </p>
    </div>

    <hr class="border-gray-100 mb-8" />

    <!-- ACT -->
    <div class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 mb-1">ACT — Acceptance and Commitment Therapy</h2>
      <p class="text-sm text-gray-400 mb-3">טיפול בקבלה ומחויבות</p>
      <p class="text-gray-600 leading-relaxed mb-4">
        גישה טיפולית המתמקדת בקבלה של מחשבות ורגשות — גם כאלה שמסבים לנו כאב — ובמחויבות לפעול בהתאם לערכים שלנו.
      </p>
      <p class="text-gray-600 leading-relaxed">
        ACT לא שואל "איך לא לחשוב את המחשבה הזו" אלא "איך אוכל לחיות חיים מלאים ומשמעותיים גם כשהמחשבה הזו נוכחת".
      </p>
    </div>

    <!-- לאיזה מצבים מתאים -->
    <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">לאיזה מצבים מתאים התהליך?</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-12">
      {['חרדה', 'דכדוך', 'לחץ', 'קשי התמודדות', 'תקיעות', 'מחשבות טורדניות'].map(item => (
        <div class="border border-gray-200 rounded-lg p-4 text-center">
          <p class="text-gray-700">{item}</p>
        </div>
      ))}
    </div>

    <!-- מה אני מציע -->
    <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">מה אני מציע</h2>
    <ul class="space-y-3 mb-12">
      {[
        'טיפול LI-CBT ממוקד ומובנה',
        'תהליך מותאם אישית, בקצב שלך',
        'כלים מעשיים לשינוי דפוסי מחשבה',
        'חיבור לשילוב של יצירה, גמישות וחוויות',
        'חדר בטוח, קשוב ואנושי',
        'מפגשים פרונטאליים בגני תקווה או אונליין',
      ].map(item => (
        <li class="flex items-start gap-3">
          <span class="text-[#5ba4a4] font-bold mt-0.5">✓</span>
          <span class="text-gray-700">{item}</span>
        </li>
      ))}
    </ul>

    <!-- חשוב לדעת -->
    <div class="border border-amber-200 bg-amber-50 rounded-lg p-5 mb-12 text-sm text-amber-800">
      <p class="font-semibold mb-2">חשוב לדעת</p>
      <ul class="space-y-1">
        <li>• אני איני פסיכולוג ואינני מוסמך לבצע אבחונים קליניים</li>
        <li>• הטיפול אינו מהווה תחליף להמלצות רפואיות</li>
        <li>• אני איני עוסק בטיפול במקרים פסיכיאטריים, הפרעות סכיזופרניה, OCD חמור ואנשים לאחר אשפוז</li>
      </ul>
    </div>

    <div class="text-center">
      <a
        href="/contact"
        class="inline-block text-white font-medium px-8 py-3 rounded-full transition-colors"
        style="background-color: #5ba4a4;"
        onmouseover="this.style.backgroundColor='#4a8a8a'"
        onmouseout="this.style.backgroundColor='#5ba4a4'"
      >
        לתיאום פגישה ראשונה
      </a>
    </div>
  </section>

</BaseLayout>
