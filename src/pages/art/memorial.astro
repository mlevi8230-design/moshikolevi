---
import BaseLayout from '../../layouts/BaseLayout.astro';
import artworks from '../../data/artworks.json';

const memorialArts = artworks.filter(a => a.category === 'memorial');
const ironSwords = memorialArts.filter(a => a.slug.includes('חרבות-ברזל'));
const others = memorialArts.filter(a => !a.slug.includes('חרבות-ברזל'));
---

<BaseLayout title="ציורי הנצחה" description="ציורי הנצחה מאת מושיקו לוי — דור שלא יחזור, חרבות ברזל">

  <section class="max-w-5xl mx-auto px-6 pt-14 pb-16">
    <h1 class="text-3xl font-bold text-gray-800 mb-2 text-center">ציורי הנצחה</h1>
    <p class="text-center text-gray-500 leading-relaxed mb-12 max-w-xl mx-auto text-sm">
      אוסף פורטרטים שנוצרו לכבד את זכרם של אהובים שאינם איתנו עוד, ושל חללי מלחמת חרבות ברזל.
    </p>

    <!-- דור שלא יחזור + אחרים -->
    {others.length > 0 && (
      <>
        <h2 class="text-lg font-bold text-gray-700 mb-5 border-b border-gray-100 pb-2">דור שלא יחזור</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 mb-12">
          {others.map(art => (
            <a
              href={`/art/drawings/${art.slug}`}
              class="group block overflow-hidden rounded-lg bg-gray-50 border border-gray-100 hover:border-[#5ba4a4] transition-colors"
            >
              <div class="aspect-square overflow-hidden">
                <img
                  src={`/images/artworks/${art.imageId}`}
                  alt={art.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
              <div class="p-2.5">
                <p class="text-sm font-medium text-gray-700 truncate">{art.title}</p>
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    <!-- חרבות ברזל -->
    {ironSwords.length > 0 && (
      <>
        <h2 class="text-lg font-bold text-gray-700 mb-5 border-b border-gray-100 pb-2">חרבות ברזל — שביעי לאוקטובר</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          {ironSwords.map(art => (
            <a
              href={`/art/drawings/${art.slug}`}
              class="group block overflow-hidden rounded-lg bg-gray-50 border border-gray-100 hover:border-[#5ba4a4] transition-colors"
            >
              <div class="aspect-square overflow-hidden">
                <img
                  src={`/images/artworks/${art.imageId}`}
                  alt={art.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
              <div class="p-2.5">
                <p class="text-sm font-medium text-gray-700 truncate">{art.title}</p>
                {art.description && <p class="text-xs text-gray-400 truncate mt-0.5">{art.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </section>

</BaseLayout>
