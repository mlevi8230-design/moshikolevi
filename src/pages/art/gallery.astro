---
import BaseLayout from '../../layouts/BaseLayout.astro';
import artworks from '../../data/artworks.json';

const galleryArts = artworks.filter(a => a.category === 'gallery');
---

<BaseLayout title="גלריה" description="גלריה של מושיקו לוי — ציורי אקריליק, עפרונות, צבעי מים">

  <section class="max-w-5xl mx-auto px-6 pt-14 pb-16">
    <h1 class="text-3xl font-bold text-gray-800 mb-2 text-center">גלריה</h1>
    <p class="text-center text-gray-400 text-sm mb-10">אקריליק, עפרונות, צבעי מים — {galleryArts.length} עבודות</p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {galleryArts.map(art => (
        <a
          href={`/art/drawings/${art.slug}`}
          class="group block overflow-hidden rounded-lg bg-gray-50 border border-gray-100 hover:border-[#5ba4a4] transition-colors"
        >
          <div class="aspect-square overflow-hidden">
            <img
              src={`/images/artworks/${art.imageId}`}
              alt={art.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-2.5">
            <p class="text-sm font-medium text-gray-700 truncate">{art.title}</p>
            {art.medium && <p class="text-xs text-gray-400 truncate mt-0.5">{art.medium}</p>}
          </div>
        </a>
      ))}
    </div>

    <!-- קישור לציורי הנצחה -->
    <div class="mt-12 text-center border-t border-gray-100 pt-10">
      <p class="text-gray-500 text-sm mb-3">ראו גם:</p>
      <a href="/art/memorial" class="text-[#5ba4a4] hover:underline text-sm font-medium">
        ציורי הנצחה ←
      </a>
    </div>
  </section>

</BaseLayout>
