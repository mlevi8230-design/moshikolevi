---
import BaseLayout from '../../layouts/BaseLayout.astro';

const items = [
  { src: '/images/for-sale/artwork-2.jpg', title: 'עבודה דיגיטלית' },
  { src: '/images/for-sale/artwork-3.jpg', title: 'עבודה דיגיטלית' },
  { src: '/images/for-sale/artwork-4.jpg', title: 'עבודה דיגיטלית' },
  { src: '/images/gallery/wild-sunset.jpg', title: 'Wild Sunset' },
  { src: '/images/gallery/warrior.jpg', title: 'Warrior' },
  { src: '/images/gallery/meditation-on-the-beach.jpg', title: 'Meditation on the Beach' },
];
---

<BaseLayout title="ציורים למכירה" description="ציורים דיגיטליים של מושיקו לוי למכירה — הדפסים ומקוריות">

  <section class="max-w-4xl mx-auto px-6 pt-14 pb-16">
    <h1 class="text-3xl font-bold text-gray-800 mb-2 text-center">ציורים למכירה</h1>
    <p class="text-center text-gray-400 text-sm mb-4">הדפסים ועבודות מקוריות</p>
    <p class="text-center text-gray-500 text-sm mb-10">
      לפרטים ומחירים — <a href="https://wa.me/+972542400106" class="text-[#5ba4a4] hover:underline">צרו קשר בWhatsApp</a>
    </p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {items.map(item => (
        <div class="border border-gray-200 rounded-lg overflow-hidden group hover:border-[#5ba4a4] transition-colors">
          <div class="aspect-square overflow-hidden bg-gray-50">
            <img
              src={item.src}
              alt={item.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-3">
            <p class="text-sm font-medium text-gray-700">{item.title}</p>
            <a
              href="https://wa.me/+972542400106"
              target="_blank"
              rel="noopener"
              class="mt-2 text-xs text-[#5ba4a4] hover:underline inline-block"
            >
              לפרטים ומחיר ←
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-gray-500 mb-4">מעוניינים בעבודה ספציפית? אני שמח לדון</p>
      <a
        href="https://wa.me/+972542400106"
        target="_blank"
        rel="noopener"
        class="inline-block text-white font-medium px-8 py-3 rounded-full transition-colors"
        style="background-color: #5ba4a4;"
        onmouseover="this.style.backgroundColor='#4a8a8a'"
        onmouseout="this.style.backgroundColor='#5ba4a4'"
      >
        שלחו הודעה ב-WhatsApp
      </a>
    </div>
  </section>

</BaseLayout>
