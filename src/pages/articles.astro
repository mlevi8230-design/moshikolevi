---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="מאמרים" description="מאמרים ומחשבות מאת מושיקו לוי">

  <section class="max-w-3xl mx-auto px-6 pt-14 pb-16">
    <h1 class="text-3xl font-bold text-gray-800 mb-2 text-center">מאמרים</h1>
    <p class="text-center text-gray-400 text-sm mb-12">מחשבות, כלים ותובנות מהדרך הטיפולית</p>

    <div class="text-center text-gray-400 py-16">
      <p class="text-lg mb-2">בקרוב...</p>
      <p class="text-sm">מאמרים יתפרסמו כאן בקרוב</p>
    </div>
  </section>

</BaseLayout>
