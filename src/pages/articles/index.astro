---
import BaseLayout from '../../layouts/BaseLayout.astro';
import articles from '../../data/articles.json';
---

<BaseLayout title="מאמרים" description="מאמרים ומחשבות מאת מושיקו לוי — טיפול ACT, לחץ נפשי, גירושים וקבלת החלטות">

  <section class="max-w-3xl mx-auto px-6 pt-14 pb-16">
    <h1 class="text-3xl font-bold text-gray-800 mb-2 text-center">מאמרים</h1>
    <p class="text-center text-gray-400 text-sm mb-12">מחשבות, כלים ותובנות מהדרך הטיפולית</p>

    <div class="flex flex-col gap-5">
      {articles.map(article => (
        <a
          href={`/articles/${article.slug}`}
          class="group block border border-gray-200 rounded-xl p-6 hover:border-[#5ba4a4] hover:shadow-sm transition-all"
        >
          <h2 class="text-lg font-bold text-gray-800 mb-2 group-hover:text-[#5ba4a4] transition-colors">
            {article.title}
          </h2>
          <p class="text-sm text-gray-500 leading-relaxed">{article.description}</p>
          <span class="inline-block mt-4 text-xs text-[#5ba4a4] font-medium">קרא עוד ←</span>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
