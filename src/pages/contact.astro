---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="יצירת קשר" description="צרו קשר עם מושיקו לוי — טלפון, מייל, WhatsApp">

  <section class="max-w-2xl mx-auto px-6 pt-14 pb-16">
    <h1 class="text-3xl font-bold text-gray-800 mb-2 text-center">יצירת קשר</h1>
    <p class="text-center text-gray-400 text-sm mb-12">מוזמנים להיות בקשר לכל שאלה או בירור</p>

    <div class="space-y-4">

      <!-- טלפון -->
      <a href="tel:+972542400106" class="flex items-center gap-5 p-5 border border-gray-200 rounded-lg hover:border-[#5ba4a4] transition-colors group">
        <div class="w-11 h-11 rounded-full flex items-center justify-center text-xl shrink-0" style="background-color: #e8f5f5;">
          📞
        </div>
        <div>
          <p class="text-xs text-gray-400 mb-0.5">טלפון</p>
          <p class="font-bold text-gray-800 text-lg">054-240-0106</p>
        </div>
      </a>

      <!-- WhatsApp -->
      <a href="https://wa.me/+972542400106" target="_blank" rel="noopener" class="flex items-center gap-5 p-5 border border-gray-200 rounded-lg hover:border-green-400 transition-colors group">
        <div class="w-11 h-11 rounded-full flex items-center justify-center text-xl shrink-0 bg-green-50">
          💬
        </div>
        <div>
          <p class="text-xs text-gray-400 mb-0.5">WhatsApp</p>
          <p class="font-bold text-gray-800">שלחו הודעה</p>
        </div>
      </a>

      <!-- מייל -->
      <a href="mailto:mlevi8230@gmail.com" class="flex items-center gap-5 p-5 border border-gray-200 rounded-lg hover:border-[#5ba4a4] transition-colors group">
        <div class="w-11 h-11 rounded-full flex items-center justify-center text-xl shrink-0" style="background-color: #e8f5f5;">
          ✉️
        </div>
        <div>
          <p class="text-xs text-gray-400 mb-0.5">אימייל</p>
          <p class="font-bold text-gray-800">mlevi8230@gmail.com</p>
        </div>
      </a>

      <!-- כתובת -->
      <div class="flex items-center gap-5 p-5 border border-gray-200 rounded-lg">
        <div class="w-11 h-11 rounded-full flex items-center justify-center text-xl shrink-0" style="background-color: #e8f5f5;">
          📍
        </div>
        <div>
          <p class="text-xs text-gray-400 mb-0.5">כתובת</p>
          <p class="font-bold text-gray-800">רחוב התבור 7</p>
          <p class="text-gray-600 text-sm">גני תקווה</p>
        </div>
      </div>
    </div>

    <!-- רשתות חברתיות -->
    <div class="mt-10 text-center">
      <p class="text-gray-400 text-sm mb-4">עקבו אחרי</p>
      <div class="flex justify-center gap-6">
        <a href="https://www.instagram.com/moshikoleviart/" target="_blank" rel="noopener" class="text-gray-400 hover:text-pink-500 transition-colors" aria-label="Instagram">
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/moshiko.levy.794" target="_blank" rel="noopener" class="text-gray-400 hover:text-blue-600 transition-colors" aria-label="Facebook">
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
