---
const currentPath = Astro.url.pathname;

const therapyLinks = [
  { href: '/', label: 'דף הבית' },
  { href: '/treatment', label: 'שיטת הטיפול' },
  { href: '/about', label: 'קצת עליי' },
  { href: '/articles', label: 'מאמרים' },
  { href: '/contact', label: 'יצירת קשר' },
];

const artLinks = [
  { href: '/art', label: 'אמנות' },
  { href: '/art/gallery', label: 'גלריה' },
  { href: '/art/for-sale', label: 'ציורים למכירה' },
  { href: '/art/portrait', label: 'ציור על פי תמונה' },
];

const isArtPage = currentPath === '/art' || currentPath.startsWith('/art/');
const isMeditationPage = currentPath.startsWith('/meditation');
const activeLinks = isArtPage ? artLinks : therapyLinks;
const homeHref = isArtPage ? '/art' : isMeditationPage ? '/meditation' : '/';
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between gap-4">

    <!-- לוגו + שם -->
    <a href={homeHref} class="flex items-center gap-2 shrink-0">
      <img src="/images/about/logo.png" alt="מושיקו לוי" class="w-10 h-10 object-contain" />
    </a>

    <!-- ניווט ראשי — דסקטופ -->
    <nav class="hidden md:flex items-center gap-1 flex-1 justify-center">
      {activeLinks.map(link => (
        <a
          href={link.href}
          class={`px-3 py-1.5 rounded text-sm transition-colors ${
            currentPath === link.href
              ? 'text-[#5ba4a4] font-semibold'
              : 'text-gray-600 hover:text-[#5ba4a4]'
          }`}
        >
          {link.label}
        </a>
      ))}
      {!isArtPage && !isMeditationPage && (
        <a href="/art" class="px-3 py-1.5 rounded text-sm text-gray-400 hover:text-[#5ba4a4] transition-colors border-r border-gray-200 mr-1 pr-3">
          אמנות
        </a>
      )}
      {isArtPage && (
        <a href="/" class="px-3 py-1.5 rounded text-sm text-gray-400 hover:text-[#5ba4a4] transition-colors border-r border-gray-200 mr-1 pr-3">
          טיפול
        </a>
      )}
    </nav>

    <!-- כפתור ליצירת קשר — דסקטופ -->
    <a
      href="/contact"
      class="hidden md:inline-block shrink-0 text-sm font-medium text-white px-5 py-2 rounded-full transition-colors"
      style="background-color: #5ba4a4;"
      onmouseover="this.style.backgroundColor='#4a8a8a'"
      onmouseout="this.style.backgroundColor='#5ba4a4'"
    >
      ליצירת קשר
    </a>

    <!-- מובייל: המבורגר -->
    <button id="menu-btn" class="md:hidden p-2 text-gray-600 hover:text-[#5ba4a4]" aria-label="תפריט">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- מובייל: תפריט נפתח -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-2">
      {activeLinks.map(link => (
        <a
          href={link.href}
          class={`block py-3 text-sm border-b border-gray-50 last:border-0 transition-colors ${
            currentPath === link.href ? 'text-[#5ba4a4] font-semibold' : 'text-gray-700 hover:text-[#5ba4a4]'
          }`}
        >
          {link.label}
        </a>
      ))}
      {!isArtPage && (
        <a href="/art" class="block py-3 text-sm text-gray-500 hover:text-[#5ba4a4]">אמנות</a>
      )}
      <div class="pt-3 pb-2">
        <a href="/contact" class="btn-teal text-sm text-center w-full block">ליצירת קשר</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
